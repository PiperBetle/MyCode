{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"label": "g++ compile",
			"command": "g++.exe",
			"args": [
				"\"${file}\"",
				"-static-libgcc",
				"-g",
				"-o",
				"\"${fileDirname}\"\\VScodeRunner",
				"-O2",
				"-Wall",
				"-Wextra",
				"-pedantic",
				"-std=c++20",
				"-Wl,--stack=21474783647"
			],
			"problemMatcher": [
				"$gcc"
			]
		}
	]
}